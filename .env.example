# ===== StockLab Backend 환경 변수 =====
# 이 파일을 .env로 복사하여 사용하세요

# 서버 포트 (기본: 3001)
PORT=3001

# Hugging Face API Token (KR-FinBert 감성분석)
# https://huggingface.co/settings/tokens
HF_TOKEN=

# OpenAI API Key (AI 브리핑 생성, GPT-4.1-nano)
OPENAI_API_KEY=

# Firebase Service Account JSON (Firestore 저장용, GitHub Actions에서 사용)
# JSON 문자열로 설정 (따옴표 필요 없음, 한 줄로)
FIREBASE_SERVICE_ACCOUNT=
